# PostgreSQL — подключение к локальной БД
# Пример: postgresql://postgres:your_password@localhost:5432/interview_platform?schema=public
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/interview_platform?schema=public"

# Порт HTTP-сервера
PORT=4000

# OpenRouter API key — используется в дедупликации (опционально сейчас)
# Получить: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# === LLM-провайдер для "Уточнить у ИИ" ===
# Выбирает источник LLM для чата. Варианты: groq | ollama
LLM_PROVIDER=groq

# Groq API key — бесплатный доступ к Llama 3.3 70B и другим.
# Получить: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# Или локальный Ollama (если LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:14b
