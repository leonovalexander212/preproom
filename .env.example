# Database
DATABASE_URL=postgresql://user:password@localhost:5432/interview_platform

# Server
PORT=4000
# CORS_ORIGIN=http://localhost:5173

# LLM Provider (groq | ollama)
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local, optional)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5:14b

# OpenRouter (for AI explain)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=http://localhost:4000
OPENROUTER_TITLE=Interview Platform

# Anti-cheat detection (optional — falls back to heuristic-only if missing)
HF_TOKEN=
HF_ANTICHEAT_URL=https://router.huggingface.co/hf-inference/models/openai-community/roberta-base-openai-detector
OPENROUTER_ANTICHEAT_KEY=
OPENROUTER_ANTICHEAT_MODEL=meta-llama/llama-3.3-70b-instruct

# Mock interview security
MOCK_SIGN_SECRET=change-me-to-256-bit-random-string
MOCK_MAX_PER_WEEK=1
MOCK_DURATION_MS=2100000

# Client
# VITE_API_URL=http://localhost:4000

# Questions directory (optional)
# QUESTIONS_DIR=/path/to/questions
